{
  "headers": [
    {
      "source": "/(.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.gif|.*\\.webp|.*\\.svg|.*\\.ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.woff2|.*\\.woff|.*\\.ttf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/scan-monitored",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/email-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/governance-monthly",
      "schedule": "0 8 1 * *"
    }
  ]
}
