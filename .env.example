# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY

# Server-only. Never prefix with NEXT_PUBLIC_.
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Found in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Found in: Stripe Dashboard → Products → (your Starter product) → Price ID
STRIPE_PRICE_STARTER_ID=price_...

# Found in: Stripe Dashboard → Products → (your Pro product) → Price ID
STRIPE_PRICE_PRO_ID=price_...

# Found in: Stripe Dashboard → Products → (your Enterprise product) → Price ID
STRIPE_PRICE_ENTERPRISE_ID=price_...

# ── App ───────────────────────────────────────────────────────────────────────
# Used for Stripe redirect URLs. Change to your production URL before deploying.
NEXT_PUBLIC_APP_URL=http://localhost:3000
